@{
    ViewData["Title"] = "Privacy Policy";
}
<h1>@ViewData["Title"]</h1>

<p>This is a sample privacy policy page for the MyApp demonstration.</p>

<div class="card">
    <div class="card-header">
        <h5>Privacy Information</h5>
    </div>
    <div class="card-body">
        <p>This application demonstrates:</p>
        <ul>
            <li>ASP.NET Core MVC with Entity Framework</li>
            <li>MediatR for CQRS pattern</li>
            <li>Autofac for dependency injection</li>
            <li>SQLite database integration</li>
            <li>Custom class library integration</li>
        </ul>
        <p>All user data is stored locally in an SQLite database.</p>
    </div>
</div>
